# Copy to backtest.toml and set [backtest].data to a CSV you imported into data/

[instrument]
exchange = "test"
symbol = "EXAMPLE"
asset_class = "equity"
base_asset = "EXAMPLE"
quote_asset = "USD"

[backtest]
data = "data/EXAMPLE_1d.csv"
data_format = "ohlcv"
fee_bps = 10
slippage_bps = 5
half_spread_bps = 5
# Optional; defaults to one configured lot (one share for equities).
buy_and_hold_qty = 1
periods_per_year = 252.0
strategy = "simple_sma"
python = "python"
output = "target/backtest_report.json"

[[balances]]
asset = "USD"
amount = "10000"

# Forwarded unchanged in the external strategy init message and report.
[strategy_parameters]
fast_window = 5
slow_window = 20

# Optional extra symbols for merged multi-instrument replay:
# [[instruments]]
# exchange = "test"
# symbol = "SECOND"
# asset_class = "equity"
# data = "data/SECOND_1d.csv"
# data_format = "ohlcv"
